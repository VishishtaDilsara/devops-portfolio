# EmailJS Config (Email Notifications)
# 1. Sign up on https://www.emailjs.com
# 2. Add an email service (like Gmail) and retrieve the Service ID
# 3. Create an email template and retrieve the Template ID
#    (Use variables {{from_name}}, {{from_email}}, {{from_phone}}, and {{message}} in the template body)
# 4. Retrieve your Public Key from Account > API Keys
VITE_EMAILJS_SERVICE_ID=service_sapx0bx
VITE_EMAILJS_TEMPLATE_ID=template_rzfl9nv
VITE_EMAILJS_PUBLIC_KEY=Nc3FVqDNjxM8p7MV0

# Firebase Config (Database Persistent Storage)
# Get these credentials from your Firebase Console (Project Settings > General > Your Apps)
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN
VITE_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID
